DATABASE_URL=postgresql://minyad:minyad@postgres:5432/minyad
MINYAD_TIMEZONE=Europe/Amsterdam
# Host IP address where Docker should publish Minyad services.
# Set this to the interface address you want to expose instead of 0.0.0.0.
MINYAD_BIND_IP=192.168.110.5
MINYAD_POSTGRES_HOST_PORT=15432
MINYAD_API_HOST_PORT=18000
MINYAD_DASHBOARD_HOST_PORT=18080
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
DSMR_MQTT_TOPIC=dsmr/reading
DSMR_INGESTION_ENABLED=true
DEBUG_MESSAGES=false
ENVOY_HOST=envoy.local
ENVOY_USERNAME=installer
ENVOY_PASSWORD=change-me
ENPHASE_GATEWAY_IP=envoy.local
ENPHASE_TOKEN=change-me
ENPHASE_VERIFY_TLS=false
ENPHASE_SWITCH_HYSTERESIS_S=600
ENPHASE_INGESTION_ENABLED=true
ENPHASE_STEERING_ENABLED=true
CURTAILMENT_GRANULAR_ENABLED=false
GOODWE_HOST=goodwe.local
GOODWE_MODBUS_PORT=502
GOODWE_STATION_ID=247
GOODWE_INGESTION_ENABLED=true
GOODWE_STEERING_ENABLED=true
MINYAD_LATITUDE=52.3676
MINYAD_LONGITUDE=4.9041
PV_PEAK_KW=5.0
PV_PERFORMANCE_RATIO=0.78
HTTP_TIMEOUT_S=5
