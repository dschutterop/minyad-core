DB_URL=postgresql+asyncpg://minyad:minyad@minyad-db:5432/minyad
MQTT_HOST=minyad-mqtt
MQTT_PORT=1883
MQTT_USER=minyad
MQTT_PASS=replace-with-strong-mqtt-password
MINYAD_API_SECRET=replace-with-64-character-random-secret
MINYAD_CORS_ORIGINS=http://localhost:8084,http://localhost:8085
ENCRYPTION_KEY=replace-with-fernet-key
FORECAST_LATITUDE=51.9788
FORECAST_LONGITUDE=4.3158
SOLAR_PEAK_W=5000
STRATEGY_V2_PRIMARY=false
STRATEGY3_SHADOW_MODE=false
# Production should set this to the Minyad VPN/internal interface so Prometheus
# can scrape metrics without exposing them on every host interface.
MINYAD_METRICS_BIND_IP=192.168.110.2

ENTSOE_API_KEY=replace-with-entsoe-api-key

SONAR_HOST=192.168.110.3:9000
SONAR_TOKEN=replace-with-sonarqube-token
