# Core application services
DB_URL=postgresql+asyncpg://minyad:replace-with-local-password@minyad-db:5432/minyad # REQUIRED: PostgreSQL URL for the local Minyad API and ingestion services.
MQTT_HOST=minyad-mqtt # REQUIRED: MQTT broker hostname; use the Compose service name locally.
MQTT_PORT=1883 # REQUIRED: MQTT broker TCP port.
MQTT_USER=minyad # OPTIONAL: MQTT username if broker authentication is enabled.
MQTT_PASS=replace-with-local-mqtt-password # OPTIONAL: MQTT password; generate your own value and never commit the real one.
MINYAD_API_SECRET=replace-with-random-local-api-secret # REQUIRED: Shared API secret for protected local endpoints.
MINYAD_CORS_ORIGINS=http://localhost:8084,http://localhost:8085 # REQUIRED: Browser origins allowed to call the API.
ENCRYPTION_KEY=replace-with-local-fernet-key # REQUIRED: Fernet key for encrypted local settings; generate with a trusted local tool.
MINYAD_CONTAINER_BIND_ADDR=0.0.0.0 # REQUIRED: Address services bind to inside containers.
MINYAD_MQTT_BIND_IP=127.0.0.1 # REQUIRED: Host interface where Docker publishes MQTT; keep loopback for local testing.
MINYAD_TLS_IP_SANS=127.0.0.1,192.0.2.10 # OPTIONAL: Documentation-only IP SAN examples for the internal TLS certificate.
MINYAD_HOST_DNS=minyad.local # OPTIONAL: Local DNS name included in the internal TLS certificate.
MINYAD_METRICS_BIND_IP=127.0.0.1 # REQUIRED: Host interface for published metrics; use a trusted private interface in production.
MINYAD_TIMEZONE=Europe/Amsterdam # OPTIONAL: IANA timezone for timestamps and dashboard grouping.

# Public bridge defaults
MQTT_BROKER=minyad-mqtt # REQUIRED for host bridges: target Minyad MQTT broker hostname or IP.
METRICS_ADDR=127.0.0.1 # REQUIRED for host bridges: interface where bridge Prometheus metrics listen.
LOG_LEVEL=INFO # OPTIONAL: Bridge and service log level.

# GoodWe / Modbus bridge
INVERTER_BACKEND=goodwe # REQUIRED: Inverter backend implementation to use.
GOODWE_API_HOST=192.0.2.20 # OPTIONAL: Documentation-only placeholder for the GoodWe LAN/API host.
GOODWE_API_ENABLED=true # OPTIONAL: Enable GoodWe API telemetry when available.
GOODWE_MODBUS_LIMITS_ENABLED=true # OPTIONAL: Enable Modbus charge/discharge limit writes after commissioning.
GOODWE_MODBUS_HOST=192.0.2.21 # REQUIRED for Modbus writes: RS485-to-Ethernet gateway host.
GOODWE_MODBUS_PORT=502 # REQUIRED for Modbus writes: Modbus TCP port on the gateway.
GOODWE_MODBUS_DEVICE_ID=247 # REQUIRED for Modbus writes: inverter Modbus slave/device ID.
MODBUS_TIMEOUT=5 # OPTIONAL: Modbus request timeout in seconds.
GOODWE_DRY_RUN=true # REQUIRED for commissioning: keep true until writes are verified safe.
INVERTER_MAX_W=5000 # REQUIRED: Inverter power limit in watts.
MAX_CHARGE_A=30 # REQUIRED: Requested bridge charge-current limit in amps.
MAX_ALLOWED_CHARGE_A=30 # REQUIRED: Safety ceiling for bridge charge-current limit in amps.
MAX_DISCHARGE_W=5000 # OPTIONAL: Discharge power ceiling in watts.
POLL_INTERVAL=30 # OPTIONAL: Bridge poll interval in seconds.
GOODWE_LIMIT_WRITE_INTERVAL_SEC=10 # OPTIONAL: Minimum interval between Modbus limit writes.
GOODWE_LIMIT_MIN_CHANGE_W=150 # OPTIONAL: Minimum watt change before writing a new limit.
GOODWE_DEFAULT_CHARGE_LIMIT_W=5000 # OPTIONAL: Default charge limit published to the inverter.
GOODWE_DEFAULT_DISCHARGE_LIMIT_W=5000 # OPTIONAL: Default discharge limit published to the inverter.
GOODWE_CONSERVATIVE_CHARGE_LIMIT_W=1500 # OPTIONAL: Fallback charge limit during degraded conditions.
GOODWE_CONSERVATIVE_DISCHARGE_LIMIT_W=1500 # OPTIONAL: Fallback discharge limit during degraded conditions.

# DSMR / P1 bridge
DSMR_MQTT_BROKER=192.0.2.30 # REQUIRED: Documentation-only placeholder for the source DSMR MQTT broker.
DSMR_MQTT_PORT=1883 # REQUIRED: Source DSMR MQTT broker port.
DSMR_MQTT_USER=replace-with-dsmr-user # OPTIONAL: Source DSMR MQTT username.
DSMR_MQTT_PASS=replace-with-dsmr-password # OPTIONAL: Source DSMR MQTT password.
DSMR_TOPIC_PREFIX=dsmr/reading # REQUIRED: Source topic prefix published by your DSMR reader.
MINYAD_TOPIC_PREFIX=minyad/grid # REQUIRED: Target Minyad grid topic prefix.
STALE_TIMEOUT=60 # OPTIONAL: Seconds before DSMR data is marked stale.
DEAD_TIMEOUT=300 # OPTIONAL: Seconds before DSMR data is marked disconnected.

# Enphase Envoy-S bridge
ENPHASE_ENVOY_HOST=192.0.2.40 # REQUIRED: Documentation-only placeholder for the Envoy-S host.
ENPHASE_TOKEN_FILE=/opt/minyad/host-services/.token # REQUIRED: Path to a local owner-token file; never commit the token.
ENPHASE_ENVOY_TIMEOUT=10 # OPTIONAL: Envoy request timeout in seconds.
ENPHASE_PRODUCTION_POLL_INTERVAL=10 # OPTIONAL: Production telemetry poll interval in seconds.
ENPHASE_INVERTER_POLL_INTERVAL=60 # OPTIONAL: Inverter telemetry poll interval in seconds.

# Optional notifications
NTFY_TOPIC=minyad-local-alerts # OPTIONAL: ntfy topic name for local alert forwarding; use a dummy value in examples.
