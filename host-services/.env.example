INVERTER_BACKEND=goodwe # REQUIRED: Host bridge backend implementation.
GOODWE_API_HOST=192.0.2.20 # OPTIONAL: Documentation-only placeholder for the GoodWe API/LAN host.
INVERTER_MAX_W=5000 # REQUIRED: Inverter power limit in watts.
GOODWE_MODBUS_HOST=192.0.2.21 # REQUIRED: Documentation-only placeholder for the RS485-to-Ethernet Modbus gateway.
GOODWE_MODBUS_PORT=502 # REQUIRED: Modbus TCP port exposed by the gateway.
GOODWE_MODBUS_DEVICE_ID=247 # REQUIRED: Inverter Modbus slave/device ID.
MODBUS_TIMEOUT=5 # OPTIONAL: Modbus request timeout in seconds.
MQTT_BROKER=minyad-mqtt # REQUIRED: Target Minyad MQTT broker host.
MQTT_PORT=1883 # REQUIRED: Target Minyad MQTT broker port.
MQTT_USER=replace-with-mqtt-user # OPTIONAL: Target MQTT username.
MQTT_PASS=replace-with-mqtt-password # OPTIONAL: Target MQTT password.
POLL_INTERVAL=30 # OPTIONAL: Bridge poll interval in seconds.
MAX_CHARGE_A=30 # REQUIRED: Requested GoodWe bridge charge-current limit in amps.
MAX_ALLOWED_CHARGE_A=30 # REQUIRED: Absolute safety ceiling for charge-current limit in amps.
LOG_LEVEL=INFO # OPTIONAL: Bridge log level.
METRICS_ADDR=127.0.0.1 # REQUIRED: Interface for host-service Prometheus metrics.

DSMR_MQTT_BROKER=192.0.2.30 # REQUIRED: Documentation-only placeholder for the source DSMR MQTT broker.
DSMR_MQTT_PORT=1883 # REQUIRED: Source DSMR MQTT broker port.
DSMR_MQTT_USER=replace-with-dsmr-user # OPTIONAL: Source DSMR MQTT username.
DSMR_MQTT_PASS=replace-with-dsmr-password # OPTIONAL: Source DSMR MQTT password.
DSMR_TOPIC_PREFIX=dsmr/reading # REQUIRED: Source DSMR topic prefix.
MINYAD_TOPIC_PREFIX=minyad/grid # REQUIRED: Target Minyad grid topic prefix.
STALE_TIMEOUT=60 # OPTIONAL: Seconds before DSMR data is marked stale.
DEAD_TIMEOUT=300 # OPTIONAL: Seconds before DSMR data is marked disconnected.

ENPHASE_ENVOY_HOST=192.0.2.40 # REQUIRED: Documentation-only placeholder for the Envoy-S host.
ENPHASE_TOKEN_FILE=/opt/minyad/host-services/.token # REQUIRED: Path to local Enphase owner-token file; never commit the token.
ENPHASE_ENVOY_TIMEOUT=10 # OPTIONAL: Envoy request timeout in seconds.
ENPHASE_PRODUCTION_POLL_INTERVAL=10 # OPTIONAL: Production telemetry poll interval in seconds.
ENPHASE_INVERTER_POLL_INTERVAL=60 # OPTIONAL: Inverter telemetry poll interval in seconds.
